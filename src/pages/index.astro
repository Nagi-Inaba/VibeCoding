---
import '../styles/custom.css';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const link = (path) => new URL(path, new URL(base, 'https://example.com')).pathname;
const navItems = [
  ['start/', 'はじめの一歩'],
  ['what-is-vibe-coding/', '考え方'],
  ['short-prompts/', '短い指示'],
  ['asking/', '場面別の頼み方'],
  ['folder-structure/', 'フォルダ構成'],
  ['recover/', '戻し方'],
  ['work-log/', '作業記録'],
  ['common-mistakes/', 'よくある失敗'],
  ['my-vibe-coding/', '近道'],
  ['tools/', 'ツール'],
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="短い指示でAIが動ける環境を作る、バイブコーディング初心者向けガイド。" />
    <title>Vibe Coding Guide</title>
    <link rel="icon" href={link('favicon.svg')} type="image/svg+xml" />
  </head>
  <body>
    <div class="landing-shell">
      <a class="skip-link" href="#main-content">コンテンツにスキップ</a>
      <header class="landing-topbar">
        <a class="landing-brand" href={link('./')} aria-label="Vibe Coding Guide トップ">
          <img src={link('favicon.svg')} alt="" width="34" height="34" />
          <span>Vibe Coding Guide</span>
        </a>
        <nav class="landing-nav landing-nav--desktop" aria-label="主要ナビゲーション">
          {navItems.map(([href, label]) => <a href={link(href)}>{label}</a>)}
        </nav>
        <details class="landing-menu">
          <summary>メニュー</summary>
          <nav class="landing-nav landing-nav--mobile" aria-label="モバイル主要ナビゲーション">
            {navItems.map(([href, label]) => <a href={link(href)}>{label}</a>)}
          </nav>
        </details>
      </header>

      <main id="main-content" class="landing-main" tabindex="-1">
        <section class="hero-grid" aria-labelledby="hero-title">
          <div class="hero-copy">
            <h1 id="hero-title">短い指示でAIが動ける環境を作る</h1>
            <p>使うAIを1つ選び、AIが迷わない作業場所と頼み方を整える。</p>
            <div class="hero-actions" aria-label="主要な導線">
              <a href={link('start/')}>はじめの一歩から始める <span aria-hidden="true">→</span></a>
              <a href={link('practice/')}>小さな実践例を1回通す <span aria-hidden="true">→</span></a>
            </div>
            <div class="ai-shortcut" aria-labelledby="ai-shortcut-title">
              <strong id="ai-shortcut-title">まとめて整理したいとき</strong>
              <p>作業フォルダを開けるコーディング支援AIにこのサイトのURLを貼り、「この内容を読んで、ここに書いてある進め方で私の作業環境を整えたいです」と頼むと、フォルダ構成、最初の依頼文、確認手順を整理できます。</p>
              <p>AIがURLを読めないときは、まず「はじめの一歩」と「場面別の頼み方」の本文を貼ってください。全部を一度に渡すより、必要なページから順番に渡す方が安定します。</p>
              <a href={link('my-vibe-coding/')}>大きく近道する考え方を見る <span aria-hidden="true">→</span></a>
              <a href={link('tools/')}>よく使うツールを開く <span aria-hidden="true">→</span></a>
            </div>
            <p class="reading-order-label">迷ったら、この順番</p>
            <ol class="reading-order" aria-label="読者の状態別おすすめ導線">
              <li><a href={link('what-is-vibe-coding/')}>まず理解する</a></li>
              <li><a href={link('start/')}>すぐ始める</a></li>
              <li><a href={link('recover/')}>困ったら見る</a></li>
              <li><a href={link('my-vibe-coding/')}>慣れてから広げる</a></li>
            </ol>
            <p class="after-reading">
              最初の1回は
              <a href={link('what-is-vibe-coding/')}>考え方</a>、
              <a href={link('start/')}>はじめの一歩</a>、
              <a href={link('practice/')}>小さな実践例</a>、
              <a href={link('checklists/')}>チェックリスト</a>
              だけで十分です。用語に迷ったら <a href={link('glossary/')}>用語集</a>、他の人に使ってもらうなら <a href={link('publish-check/')}>人に使ってもらう前に</a>、補助ツールが必要になったときだけ <a href={link('tools/')}>ツール</a> を開きます。
            </p>
            <div class="hero-points" aria-label="このサイトで学べること">
              <div class="point">
                <strong>使うAIを1つ選ぶ</strong>
                <span>CodexかClaude Codeのどちらかから、使うものを1つ決める。</span>
              </div>
              <div class="point">
                <strong>戻れる地点を作る</strong>
                <span>大きな変更の前に保存し、動かなくなったら止まって確認する。</span>
              </div>
              <div class="point">
                <strong>実際に触って確かめる</strong>
                <span>実画面、入力、リンク、エラー状態を見てから次へ進む。</span>
              </div>
            </div>
          </div>

          <section class="preview-shell" aria-labelledby="preview-title">
            <h2 id="preview-title" class="sr-only">ガイドサイトの内容プレビュー</h2>
            <div class="preview-nav" aria-hidden="true">
              <strong>Vibe Coding Guide</strong>
              <span aria-current="page">はじめに</span>
              <span>はじめの一歩</span>
              <span>小さな実践例</span>
              <span>短い指示が効く理由</span>
              <span>場面別の頼み方</span>
              <span>フォルダ構成</span>
              <span>うまく動かなくなったときの戻し方</span>
              <span>作業記録</span>
              <span>よくある失敗</span>
            </div>
            <div class="preview-content">
              <h2>場面別の頼み方（例）</h2>
              <table class="example-table">
                <caption>困った場面から1行だけ選んで使う頼み方の例です。</caption>
                <thead>
                  <tr><th>場面</th><th>指示</th><th>効く理由</th></tr>
                </thead>
                <tbody>
                  <tr><td>機能を作る</td><td>読書メモを1ページで表示して</td><td>作るものと範囲が明確になる。</td></tr>
                  <tr><td>バグを直す</td><td>スマホで表がはみ出す原因を直して</td><td>起きている問題と確認する画面が分かる。</td></tr>
                  <tr><td>整理する</td><td>文章を見出しと本文に分けて</td><td>対象と分け方が明確になる。</td></tr>
                  <tr><td>確認する</td><td>初めて見る人に分かりにくい表現を見て</td><td>確認観点が決まり、指摘が具体的になる。</td></tr>
                </tbody>
              </table>

              <h2>AIが作ったフォルダ構成（例）</h2>
              <div class="folder-preview">
                <pre class="tree">{`/workspace
├─ sources/
├─ notes/
├─ outputs/
└─ logs/`}</pre>
                <div class="folder-list">
                  <div class="folder-row"><strong>sources/</strong><span>元資料や参照元を置く。</span></div>
                  <div class="folder-row"><strong>notes/</strong><span>考え途中のメモを置く。</span></div>
                  <div class="folder-row"><strong>outputs/</strong><span>完成物や提出物を置く。</span></div>
                  <div class="folder-row"><strong>logs/</strong><span>作業記録や確認結果を残す。</span></div>
                </div>
              </div>
            </div>
          </section>
        </section>

        <section class="landing-next" aria-labelledby="next-title">
          <h2 id="next-title">短い指示が効く理由</h2>
          <p>使うコーディング支援AIを1つ決め、「どのフォルダで」「何を作りたいか」を伝えると、短い指示でも作業範囲を合わせやすくなります。最初の準備から確認したい人は、「はじめの一歩」から始めてください。</p>
          <div class="reason-strip">
            <div class="reason-item">
              <h3>場所が1つ決まっている</h3>
              <p>作業フォルダが決まっていると、AIがどこで作業するか迷わない。</p>
            </div>
            <div class="reason-item">
              <h3>目的が絞られている</h3>
              <p>小さな要件メモがあると、やることと後回しにすることが分かる。</p>
            </div>
            <div class="reason-item">
              <h3>確認で無駄を減らす</h3>
              <p>方針確認、戻れる地点、実画面と作業記録でやり直しを減らす。</p>
            </div>
          </div>
          <p><a class="next-link" href={link('short-prompts/')}>詳しく見る <span aria-hidden="true">→</span></a></p>
        </section>
      </main>

      <footer class="landing-footer">
        <p>内部の仕組みではなく、今日から真似できる作業の型としてまとめた初心者向けガイドです。</p>
      </footer>
    </div>
    <script>
      const mobileMenu = document.querySelector<HTMLDetailsElement>('details.landing-menu');
      const mobileMenuSummary = mobileMenu?.querySelector<HTMLElement>('summary');

      mobileMenuSummary?.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          mobileMenu.open = !mobileMenu.open;
        }
      });
    </script>
  </body>
</html>
